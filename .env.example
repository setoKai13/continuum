# raise_2 -- template d'environnement.
# Copie ce fichier vers python-desktop/.env et renseigne les valeurs.
# python-desktop/ a aussi son propre .env.example.

# --- Requis ---
# Cle Gemini. IMPORTANT (verifie 2026-07-05) : depuis le 2026-06-19 l'API rejette
# les cles standard NON restreintes -> teste ta cle avant la demo
# (voir CONNECTEURS-VERIF-2026-07-05.md).
GEMINI_API_KEY=

# Modele de vision grounding. gemini-3.5-flash (Computer Use natif) par defaut.
# Fallback : gemini-2.5-flash, ou legacy gemini-2.5-computer-use-preview-10-2025.
MODEL_NAME=gemini-3.5-flash

# --- Optionnel ---
OPENROUTER_API_KEY=
GRADIUM_API_KEY=

# --- Reglages agent (detail des variables : python-desktop/.env.example) ---
PTT_KEY=f8
KILL_KEY=esc
LANGUAGE=fr
WHISPER_MODEL=small
DB_PATH=continuum.db
LOG_PATH=continuum.log
LOG_LEVEL=INFO
MAX_TURNS=120
MAX_IDLE_TURNS=1500
LOOP_IDLE_SLEEP_S=0.4
MAX_STEP_ATTEMPTS=3
MAX_CONTEXT_SCREENSHOTS=3
PYAUTOGUI_PAUSE_S=0.1
UI_SETTLE_S=0.8
GEMINI_TIMEOUT_MS=30000
GEMINI_MAX_ATTEMPTS=3
GEMINI_BACKOFF_S=0.5
GEMINI_BREAKER_FAILURES=4
GEMINI_BREAKER_COOLDOWN_S=20
