# Continuum -- environment template. Copy to `.env` and fill in real values.

# Required for live runs (vision grounding). Get a temporary key via the
# hackathon's DeepMind Google Form.
GEMINI_API_KEY=REPLACE_WITH_REAL_KEY_TODO_TOM

# Optional -- Nemotron selector via OpenRouter (bonus sponsor path).
OPENROUTER_API_KEY=

# Optional -- Gradium voice sponsor path (STT/TTS/S2S).
GRADIUM_API_KEY=

# Gemini model used for vision grounding.
# gemini-3.5-flash (GA depuis 2026-05-19, Computer Use natif) est le defaut.
# Fallback si indispo le jour J : gemini-2.5-flash, ou le legacy
# gemini-2.5-computer-use-preview-10-2025 (voir CONNECTEURS-VERIF-2026-07-05.md).
MODEL_NAME=gemini-3.5-flash

# Optional "mastermind" model for the reasoning-heavy, once-per-instruction
# calls (planning an instruction into steps, extracting a voice-correction).
# The per-turn grounding/verify calls stay on MODEL_NAME (fast + cheap).
# Empty = MODEL_NAME does everything. Verified 2026-07-05: the strongest
# generally available reasoner is gemini-3.1-pro-preview (gemini-3.5-pro is
# not yet public).
PLANNER_MODEL=gemini-3.1-pro-preview

# Gemini 3 thinking depth for the planner calls (minimal/low/medium/high).
# Empty (recommended) = the model's DYNAMIC default: Gemini 3 picks its own
# reasoning depth per task. Forcing "high" makes simple tasks slow and
# over-planned; only pin a level for benchmarking.
PLANNER_THINKING_LEVEL=

# Adaptive grounding self-consistency. The model reports a confidence with
# each action: confident answers act on the FIRST call (fast); only answers
# below GROUND_CONFIDENCE escalate to up to GROUND_SAMPLES samples and a
# majority vote (an outlier click gets outvoted, not executed).
# GROUND_SAMPLES=1 disables escalation entirely.
GROUND_SAMPLES=3
GROUND_CONFIDENCE=0.75

# Computer Use route for the DECIDE tier (the router fast-paths run upstream
# in BOTH modes; only the model-grounded fallback changes):
#   grounding    (default) = vision path: generate_content -> normalized
#                 [ymin,xmin,ymax,xmax] box (headless-tested, the safe plan).
#   interactions = official Computer Use: client.interactions.create with
#                 ENVIRONMENT_DESKTOP, returning 0..CU_NORM_MAX {x,y} points.
# Flip to `interactions` on demo day only after scripts/probe_cu.py shows it
# grounds the target reliably against the live screen.
CU_MODE=grounding
# Model for the Interactions CU calls. Empty = reuse MODEL_NAME (gemini-3.5-flash
# ships Computer Use natively since 2026-06-24).
CU_MODEL=
# Environment operated: desktop (OS-level cursor/keyboard), browser, or mobile.
CU_ENVIRONMENT=desktop
# Normalization ceiling for the CU {x,y} points. Desktop documents 0-999; the
# SDK's browser samples say 0-1000 (a ~1px difference). Configurable to flip.
CU_NORM_MAX=999
# API-side prompt-injection detection on every CU request (recommended on).
CU_PROMPT_INJECTION_DETECTION=true
# Divisor turning a CU scroll's magnitude_in_pixels into pyautogui wheel clicks.
CU_SCROLL_PIXELS_PER_CLICK=100
# Per-request timeout (ms) for the Interactions CU calls (an agentic turn
# carries a screenshot and can run longer than a plain grounding call).
CU_TIMEOUT_MS=60000

# Push-to-talk key (held to record) and kill-switch key (stops the agent).
PTT_KEY=f8
KILL_KEY=esc

# STT priming language: fr or en.
LANGUAGE=fr

# faster-whisper model size ("small" default; "base" is faster, less accurate).
WHISPER_MODEL=small

# SQLite hold-state database path.
DB_PATH=continuum.db

# Process log file (the console belongs to the HUD; tail this in a 2nd terminal).
LOG_PATH=continuum.log
LOG_LEVEL=INFO

# Debug/demo console: when true, launching main.py opens a second Terminal
# window streaming what the model heard, planned, reasoned (with confidence),
# decided and did -- the live narration of the run. The stream is also written
# to TRACE_PATH (truncated at each boot), viewable by hand with:
#   .venv/bin/python scripts/trace_view.py continuum-trace.log
DEBUG_CONSOLE=true
TRACE_PATH=continuum-trace.log

# Keep listening after the task completes (true, default): the agent announces
# completion and the next spoken instruction starts a fresh plan in the same
# session. Set to false to exit as soon as every step is done.
KEEP_ALIVE=true

# Ceiling on WORK turns per run (turns that carry an observation and may hit
# Gemini/the actuator). Idle waiting for voice does NOT consume this budget.
MAX_TURNS=120

# Ceiling on CONSECUTIVE quiet turns (nothing heard, nothing to do) before the
# run ends on its own; with LOOP_IDLE_SLEEP_S=0.4 the default waits ~10 min.
MAX_IDLE_TURNS=1500
LOOP_IDLE_SLEEP_S=0.4

# Actions attempted on one step before it is marked blocked (a voice
# correction resets the budget for the recalibrated steps).
MAX_STEP_ATTEMPTS=3

# How many recent screenshots stay in the Gemini context window.
MAX_CONTEXT_SCREENSHOTS=3

# Delay (seconds) pyautogui inserts between actions.
PYAUTOGUI_PAUSE_S=0.1

# Pause (seconds) after each real action so the next screenshot is not taken
# mid-animation (menu opening, app launching).
UI_SETTLE_S=0.8

# Gemini outbound-call hardening: per-request timeout, retry (transient errors
# only) and circuit breaker.
GEMINI_TIMEOUT_MS=30000
# Mastermind calls (planning, override extraction) get a longer deadline:
# they run once per instruction and a thinking pro model can exceed 30s.
PLANNER_TIMEOUT_MS=120000
GEMINI_MAX_ATTEMPTS=3
GEMINI_BACKOFF_S=0.5
GEMINI_BREAKER_FAILURES=4
GEMINI_BREAKER_COOLDOWN_S=20
